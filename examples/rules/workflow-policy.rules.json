{
  "_comment": "Rule-set declarativo de la politica de workflows (forma n8n), tercer dominio de la vertiente rule contract y primer uso de la familia each. Dominio y fronteras: knowledge/data_models/workflow_policy.md.",
  "required": [
    { "field": "name" },
    { "field": "environment" },
    { "field": "settings.error_workflow" }
  ],
  "type": [
    { "field": "name", "kind": "string" },
    { "field": "environment", "kind": "string" },
    { "field": "settings", "kind": "dict" },
    { "field": "settings.execution_timeout", "kind": "number" },
    { "field": "connections", "kind": "dict" }
  ],
  "bounds": [
    { "field": "settings.execution_timeout", "gt": 0 }
  ],
  "refs": [
    { "field": "environment", "collection": "environments" }
  ],
  "keyed_bounds": [
    { "field": "settings.execution_timeout", "key": "environment", "table": "environments", "max_path": "max_execution_timeout" }
  ],
  "each": [
    {
      "collection": "nodes",
      "where": { "field": "type", "equals": "httpRequest" },
      "rules": { "required": [ { "field": "parameters.timeout" } ] }
    },
    {
      "collection": "nodes",
      "rules": { "enums": [ { "field": "credentials_inline", "values": [false] } ] }
    },
    {
      "collection": "nodes",
      "rules": { "enums": [ { "field": "type", "values": ["httpRequest", "code", "set", "webhook", "if", "merge"] } ] }
    }
  ],
  "code_only": [
    {
      "rule": "no-graph-cycles",
      "field": "connections",
      "reason": "Ningun ciclo entre nodos es una propiedad GLOBAL del grafo (exige recorrido/DFS), no una regla por elemento: each cuantifica sobre elementos individuales, no sobre caminos. Tercera clase de frontera medida (tras cross-field e identidad). Un checker de ciclos es territorio de task contract (codigo con su oraculo)."
    }
  ],
  "golden": {
    "path": "workflow-golden.json",
    "sha256": "7a08e8abfb508e65cc2f6410a98530235d25fe9cc9c3d922bc3632b0faa5fff0"
  }
}
